local SprintCorner = Instance.new("UICorner") SprintCorner.CornerRadius = UDim.new(0, 10) SprintCorner.Parent = SprintMainFrame
SprintStroke.Thickness = 1.2 SprintStroke.Parent = SprintMainFrame

SprintTitle.Size = UDim2.new(1, 0, 0, 30) SprintTitle.BackgroundTransparency = 1
SprintTitle.Text = "Sprint Module" SprintTitle.TextSize = 13 SprintTitle.Font = Enum.Font.GothamBold SprintTitle.Parent = SprintMainFrame

SprintClose.Size = UDim2.new(0, 20, 0, 20) SprintClose.Position = UDim2.new(1, -25, 0, 5) SprintClose.BorderSizePixel = 0

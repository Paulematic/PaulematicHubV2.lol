SprintActionBtn.Text = "Untoggled" SprintActionBtn.TextSize = 13 SprintActionBtn.Font = Enum.Font.GothamMedium SprintActionBtn.Parent = SprintMainFrame
local SprintActionCorner = Instance.new("UICorner") SprintActionCorner.CornerRadius = UDim.new(0, 6) SprintActionCorner.Parent = SprintActionBtn
SprintActionStroke.Thickness = 1 SprintActionStroke.Parent = SprintActionBtn

BindActionBtn.Size = UDim2.new(1, -20, 0, 40) BindActionBtn.Position = UDim2.new(0, 10, 0, 95) BindActionBtn.BorderSizePixel = 0
BindActionBtn.Text = "Keybind: LeftShift" BindActionBtn.TextSize = 12 BindActionBtn.Font = Enum.Font.GothamMedium BindActionBtn.Parent = SprintMainFrame
local BindActionCorner = Instance.new("UICorner") BindActionCorner.CornerRadius = UDim.new(0, 6) BindActionCorner.Parent = BindActionBtn
BindActionStroke.Thickness = 1 BindActionStroke.Parent = BindActionBtn

local sprintState = false
local sprintKeybind = Enum.KeyCode.LeftShift
local listeningForBind = false

local function setSprintActive(state)
	sprintState = state
	SprintMainFrame:SetAttribute("ToggledState", sprintState)
	local character = localPlayer.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local cfg = Themes[currentTheme]
	
	if sprintState then
		SprintActionBtn.Text = "Toggled"
		TweenService:Create(SprintActionBtn, TweenInfo.new(0.15), {BackgroundColor3 = cfg.TabActive, TextColor3 = cfg.TabTextActive}):Play()
		TweenService:Create(SprintActionStroke, TweenInfo.new(0.15), {Color = cfg.Accent}):Play()
		if humanoid then humanoid.WalkSpeed = 30 end
	else
		SprintActionBtn.Text = "Untoggled"
		TweenService:Create(SprintActionBtn, TweenInfo.new(0.15), {BackgroundColor3 = cfg.ButtonBg, TextColor3 = cfg.ButtonText}):Play()
		TweenService:Create(SprintActionStroke, TweenInfo.new(0.15), {Color = cfg.ButtonStroke}):Play()
		if humanoid then humanoid.WalkSpeed = 16 end
	end
end

SprintActionBtn.MouseButton1Click:Connect(function()
	setSprintActive(not sprintState)
end)

BindActionBtn.MouseButton1Click:Connect(function()
	listeningForBind = true
	BindActionBtn.Text = "...Press Any Key..."
	BindActionBtn.TextColor3 = Color3.fromRGB(255, 255, 100)
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if listeningForBind then
		if input.UserInputType == Enum.UserInputType.Keyboard then
			sprintKeybind = input.KeyCode
			listeningForBind = false
			BindActionBtn.Text = "Keybind: " .. sprintKeybind.Name
			BindActionBtn.TextColor3 = Themes[currentTheme].ButtonText
		end
	else
		if input.KeyCode == sprintKeybind then
			setSprintActive(not sprintState)
		end
	end
end)

SprintClose.MouseButton1Click:Connect(function() SprintMainFrame.Visible = false end)
SprintGuiButton.MouseButton1Click:Connect(function() SprintMainFrame.Visible = not SprintMainFrame.Visible end)

----------------------------------------------------------------
-- REWRITTEN CORRECTED FLIGHT MODULE
----------------------------------------------------------------
local flying = false
local flySpeed = 50
local flyConnection, flyBV, flyBG

function clearFlightObjects()
	if flyConnection then flyConnection:Disconnect() flyConnection = nil end
	if flyBV then flyBV:Destroy() flyBV = nil end
	if flyBG then flyBG:Destroy() flyBG = nil end
	
	local char = localPlayer.Character
	local humanoid = char and char:FindFirstChildOfClass("Humanoid")
	if humanoid then humanoid.PlatformStand = false end
end

FlyButton.MouseButton1Click:Connect(function()
	if farmActive then return end 
	flying = not flying
	local char = localPlayer.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	local humanoid = char and char:FindFirstChildOfClass("Humanoid")
	
	if not root or not humanoid then flying = false return end
	
	if flying then
		FlyButton.Text = "Fly: ON"
		FlyButton.TextColor3 = Color3.fromRGB(240, 80, 80)
		
		local camera = workspace.CurrentCamera
		
		flyBV = Instance.new("BodyVelocity")
		flyBV.Name = "HubFlyBV"
		flyBV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
		flyBV.Velocity = Vector3.new(0, 0, 0)
		flyBV.Parent = root
		
		flyBG = Instance.new("BodyGyro")
		flyBG.Name = "HubFlyBG"
		flyBG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
		flyBG.CFrame = root.CFrame
		flyBG.Parent = root
		
		flyConnection = RunService.RenderStepped:Connect(function()
			if not root.Parent or not humanoid.Parent then
				clearFlightObjects()
				return
			end
			
			humanoid.PlatformStand = true
			local lookVectors = camera.CFrame
			flyBG.CFrame = lookVectors
			
			local moveDirection = Vector3.new(0,0,0)
			
			if UserInputService:IsKeyDown(Enum.KeyCode.W) then
				moveDirection = moveDirection + lookVectors.LookVector
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.S) then
				moveDirection = moveDirection - lookVectors.LookVector
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.A) then
				moveDirection = moveDirection - lookVectors.RightVector
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.D) then
				moveDirection = moveDirection + lookVectors.RightVector
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
				moveDirection = moveDirection + Vector3.new(0, 1, 0)
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
				moveDirection = moveDirection - Vector3.new(0, 1, 0)
			end
			
			if moveDirection.Magnitude > 0 then
				flyBV.Velocity = moveDirection.Unit * flySpeed
			else
				flyBV.Velocity = Vector3.new(0, 0, 0)
			end
		end)
	else
		FlyButton.Text = "Fly: OFF"
		FlyButton.TextColor3 = Themes[currentTheme].ButtonText
		clearFlightObjects()
	end
end)


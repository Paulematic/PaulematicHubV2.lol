local Views = {}

local function createTab(name, order)
	local Tab = Instance.new("TextButton")
	Tab.Name = name
	Tab.Size = UDim2.new(1, 0, 0, 38)
	Tab.BackgroundColor3 = Color3.fromRGB(30, 16, 16)
	Tab.BorderSizePixel = 0 
	Tab.Text = "[ " .. name .. " ]"
	Tab.TextColor3 = Color3.fromRGB(175, 120, 120)
	Tab.TextSize = 13 
	Tab.Font = Enum.Font.GothamMedium
	Tab.LayoutOrder = order 
	Tab.ZIndex = 2 
	Tab.Parent = SidePanel

	local TabCorner = Instance.new("UICorner") TabCorner.CornerRadius = UDim.new(0, 8) TabCorner.Parent = Tab
	local TabStroke = Instance.new("UIStroke") TabStroke.Color = Color3.fromRGB(75, 30, 30) TabStroke.Thickness = 1 TabStroke.Parent = Tab

	local Scroller = Instance.new("ScrollingFrame")
	Scroller.Size = UDim2.new(0.92, 0, 0.92, 0) Scroller.Position = UDim2.new(0.04, 0, 0.04, 0)
	Scroller.BackgroundTransparency = 1 Scroller.BorderSizePixel = 0 Scroller.ScrollBarThickness = 4
	Scroller.ScrollBarImageColor3 = Color3.fromRGB(140, 35, 35) Scroller.Visible = false Scroller.ZIndex = 3 Scroller.Parent = ContentFrame
	
	local list = Instance.new("UIListLayout") list.Padding = UDim.new(0, 12) list.HorizontalAlignment = Enum.HorizontalAlignment.Center list.SortOrder = Enum.SortOrder.LayoutOrder list.Parent = Scroller

	Views[name] = {Button = Tab, Frame = Scroller, Stroke = TabStroke}
	registeredTabs[name] = {Button = Tab, Stroke = TabStroke}

	Tab.MouseEnter:Connect(function() 
		local cfg = Themes[currentTheme]
		if MainFrame:AttributeGet("ActiveTab") ~= name then
			TweenService:Create(Tab, TweenInfo.new(0.2), {BackgroundColor3 = cfg.ButtonHover, TextColor3 = cfg.TabTextActive}):Play() 
		end
	end)
	Tab.MouseLeave:Connect(function()
		local cfg = Themes[currentTheme]
		if MainFrame:AttributeGet("ActiveTab") ~= name then
			TweenService:Create(Tab, TweenInfo.new(0.2), {BackgroundColor3 = cfg.TabInactive, TextColor3 = cfg.TabTextInactive}):Play()
		end
	end)
	
	Tab.MouseButton1Click:Connect(function()
		MainFrame:SetAttribute("ActiveTab", name)
		local cfg = Themes[currentTheme]
		for tName, data in pairs(Views) do
			local active = (tName == name)
			data.Frame.Visible = active
			data.Button.BackgroundColor3 = active and cfg.TabActive or cfg.TabInactive
			data.Button.TextColor3 = active and cfg.TabTextActive or cfg.TabTextInactive
			data.Stroke.Color = active and cfg.Accent or cfg.ButtonStroke
		end
	end)
end

createTab("General", 1)
createTab("MM2", 2)
createTab("Farming", 3)
createTab("Themes", 4)

MainFrame:SetAttribute("ActiveTab", "General")
Views["General"].Frame.Visible = true

----------------------------------------------------------------
-- HELPER GENERATOR FOR LIGHTWEIGHT BUTTONS
----------------------------------------------------------------
local function createFeatureButton(text, parent)
	local Btn = Instance.new("TextButton")
	Btn.Size = UDim2.new(1, 0, 0, 42) Btn.BackgroundColor3 = Color3.fromRGB(28, 14, 14) Btn.BorderSizePixel = 0
	Btn.Text = text Btn.TextColor3 = Color3.fromRGB(210, 160, 160) Btn.TextSize = 14 Btn.Font = Enum.Font.GothamMedium Btn.ZIndex = 4 Btn.Parent = parent
	local c = Instance.new("UICorner") c.CornerRadius = UDim.new(0, 6) c.Parent = Btn
	local s = Instance.new("UIStroke") s.Color = Color3.fromRGB(70, 30, 30) s.Thickness = 1 s.Parent = Btn
	
	registeredButtons[Btn] = {Stroke = s}
	
	Btn.MouseEnter:Connect(function() 
		local cfg = Themes[currentTheme]
		TweenService:Create(Btn, TweenInfo.new(0.15), {BackgroundColor3 = cfg.ButtonHover}):Play() 
	end)
	Btn.MouseLeave:Connect(function() 
		local cfg = Themes[currentTheme]
		TweenService:Create(Btn, TweenInfo.new(0.15), {BackgroundColor3 = cfg.ButtonBg}):Play() 
	end)
	return Btn
end


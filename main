	IYButton.Text = "Running loadstring..."
	IYButton.TextColor3 = Color3.fromRGB(255, 255, 100)
	task.spawn(function()
		pcall(function()
			loadstring(game:HttpGet("https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source"))()
		end)
	end)
	task.wait(1)
	IYButton.Text = "Infinite Yield Loaded!"
	IYButton.TextColor3 = Color3.fromRGB(100, 255, 100)
end)

-- Walkspeed Slider Assembly
local SliderFrame = Instance.new("Frame")
SliderFrame.Size = UDim2.new(1, 0, 0, 55) SliderFrame.BackgroundTransparency = 1 SliderFrame.ZIndex = 4 SliderFrame.Parent = Views["General"].Frame

local SliderLabel = Instance.new("TextLabel")
SliderLabel.Size = UDim2.new(1, 0, 0, 20) SliderLabel.BackgroundTransparency = 1 SliderLabel.Text = "WalkSpeed: 16"
SliderLabel.TextColor3 = Color3.fromRGB(200, 150, 150) SliderLabel.TextSize = 12 SliderLabel.Font = Enum.Font.Gotham SliderLabel.ZIndex = 4 SliderLabel.Parent = SliderFrame

local SliderBar = Instance.new("TextButton")
SliderBar.Size = UDim2.new(1, -12, 0, 6) SliderBar.Position = UDim2.new(0, 6, 0, 28) SliderBar.BackgroundColor3 = Color3.fromRGB(40, 20, 20)
SliderBar.Text = "" SliderBar.BorderSizePixel = 0 SliderBar.ZIndex = 4 SliderBar.Parent = SliderFrame

local BarCorner = Instance.new("UICorner") BarCorner.CornerRadius = UDim.new(0, 4) BarCorner.Parent = SliderBar

local SliderFill = Instance.new("Frame")
SliderFill.Size = UDim2.new(0, 0, 1, 0) SliderFill.BackgroundColor3 = Color3.fromRGB(150, 35, 35) SliderFill.BorderSizePixel = 0 SliderFill.ZIndex = 4 SliderFill.Parent = SliderBar

local FillCorner = Instance.new("UICorner") FillCorner.CornerRadius = UDim.new(0, 4) FillCorner.Parent = SliderFill

local SliderHandle = Instance.new("Frame")
SliderHandle.Size = UDim2.new(0, 14, 0, 14) SliderHandle.Position = UDim2.new(0, -7, 0.5, -7) SliderHandle.BackgroundColor3 = Color3.fromRGB(190, 40, 40)
SliderHandle.BorderSizePixel = 0 SliderHandle.ZIndex = 5 SliderHandle.Parent = SliderBar

local HandleCorner = Instance.new("UICorner") HandleCorner.CornerRadius = UDim.new(1, 0) HandleCorner.Parent = SliderHandle
local HandleStroke = Instance.new("UIStroke") HandleStroke.Color = Color3.fromRGB(255, 90, 90) HandleStroke.Thickness = 1 HandleStroke.Parent = SliderHandle

local minSpeed, maxSpeed = 16, 150
local isSliding = false

local function updateSlider(input)
	local ratio = math.clamp((input.Position.X - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X, 0, 1)
	SliderFill.Size = UDim2.new(ratio, 0, 1, 0)
	SliderHandle.Position = UDim2.new(ratio, -7, 0.5, -7)
	
	local speed = math.floor(minSpeed + (ratio * (maxSpeed - minSpeed)))
	SliderLabel.Text = "WalkSpeed: " .. speed
	
	local character = localPlayer.Character
	if character and character:FindFirstChildOfClass("Humanoid") then
		character:FindFirstChildOfClass("Humanoid").WalkSpeed = speed
	end
end

SliderBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isSliding = true SliderHandle.Size = UDim2.new(0, 16, 0, 16) SliderHandle.Position = UDim2.new(SliderFill.Size.X.Scale, -8, 0.5, -8) updateSlider(input)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if isSliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		updateSlider(input)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isSliding = false SliderHandle.Size = UDim2.new(0, 14, 0, 14) SliderHandle.Position = UDim2.new(SliderFill.Size.X.Scale, -7, 0.5, -7)
	end
end)

----------------------------------------------------------------
-- RUNTIME GENERAL NOCLIP SYSTEM
----------------------------------------------------------------
local generalNoclip = false
local noclipConnection = nil

local function startNoclip()
	noclipConnection = RunService.Stepped:Connect(function()
		local char = localPlayer.Character
		if char then
			for _, part in ipairs(char:GetDescendants()) do
				if part:IsA("BasePart") and part.CanCollide then
					part.CanCollide = false
				end
			end
		end
	end)
end

local function stopNoclip()
	if noclipConnection then
		noclipConnection:Disconnect()
		noclipConnection = nil
	end
	local char = localPlayer.Character
	if char then
		for _, part in ipairs(char:GetDescendants()) do
			if part:IsA("BasePart") then
				if part.Name == "HumanoidRootPart" or part.Name == "UpperTorso" or part.Name == "LowerTorso" or part.Name == "Torso" or part.Name == "Head" then
					part.CanCollide = true
				end
			end
		end
	end
end

NoclipButton.MouseButton1Click:Connect(function()
	generalNoclip = not generalNoclip
	if generalNoclip then
		NoclipButton.Text = "Noclip: ON"
		NoclipButton.TextColor3 = Color3.fromRGB(240, 80, 80)
		startNoclip()
	else
		NoclipButton.Text = "Noclip: OFF"
		NoclipButton.TextColor3 = Themes[currentTheme].ButtonText
		stopNoclip()
	end
end)

----------------------------------------------------------------
-- MM2 TAB ELEMENTS
----------------------------------------------------------------
local EspButton = createFeatureButton("Murderer/Sheriff ESP: OFF", Views["MM2"].Frame)
local GunEspButton = createFeatureButton("Dropped Gun ESP: OFF", Views["MM2"].Frame)
local SprintGuiButton = createFeatureButton("Open Sprint GUI", Views["MM2"].Frame)
local AutoGetGunButton = createFeatureButton("Auto Get Gun: OFF", Views["MM2"].Frame)
local MurderWinButton = createFeatureButton("Auto Win Murderer", Views["MM2"].Frame)

local espActive = false
local gunEspActive = false
local espContainer = nil
local gunEspContainer = nil

local function getPlayerRole(player)
	local back = player:FindFirstChild("Backpack")
	local char = player.Character
	if (back and back:FindFirstChild("Knife")) or (char and char:FindFirstChild("Knife")) then
		return "Murderer"
	elseif (back and back:FindFirstChild("Gun")) or (char and char:FindFirstChild("Gun")) then
		return "Sheriff"
	end
	return "Innocent"
end

local function cleanEsp()
	if espContainer then espContainer:Destroy() espContainer = nil end
end

local function applyEsp(player, char)
	if player == localPlayer or not espContainer then return end
	local root = char:WaitForChild("HumanoidRootPart", 5)
	if not root then return end
	
	local highlight = Instance.new("Highlight")
	highlight.Name = player.Name .. "_Esp"
	highlight.Adornee = char
	highlight.FillTransparency = 0.5
	highlight.OutlineTransparency = 0
	highlight.Parent = espContainer

	task.spawn(function()
		while espActive and char.Parent and root.Parent and highlight.Parent do
			local role = getPlayerRole(player)
			if role == "Murderer" then
				highlight.FillColor = Color3.fromRGB(255, 0, 0)
				highlight.OutlineColor = Color3.fromRGB(255, 50, 50)
			elseif role == "Sheriff" then
				highlight.FillColor = Color3.fromRGB(0, 0, 255)
				highlight.OutlineColor = Color3.fromRGB(50, 50, 255)
			else
				highlight.FillColor = Color3.fromRGB(0, 255, 0)
				highlight.OutlineColor = Color3.fromRGB(50, 255, 50)
			end
			task.wait(0.5)
		end
	end)
end

EspButton.MouseButton1Click:Connect(function()
	espActive = not espActive
	if espActive then
		EspButton.Text = "Murderer/Sheriff ESP: ON"
		EspButton.TextColor3 = Color3.fromRGB(240, 80, 80)
		
		espContainer = Instance.new("Folder")
		espContainer.Name = "MM2_ESP_Container"
		espContainer.Parent = ScreenGui
		
		local function setupPlayer(p)
			if p.Character then task.spawn(applyEsp, p, p.Character) end
			p.CharacterAdded:Connect(function(c)
				if espActive then task.spawn(applyEsp, p, c) end
			end)
		end
		
		for _, p in ipairs(Players:GetPlayers()) do setupPlayer(p) end
		Players.PlayerAdded:Connect(setupPlayer)
	else
		EspButton.Text = "Murderer/Sheriff ESP: OFF"
		EspButton.TextColor3 = Themes[currentTheme].ButtonText
		cleanEsp()
	end
end)

----------------------------------------------------------------
-- DROPPED GUN ESP UPDATES
----------------------------------------------------------------
local function cleanGunEsp()
	if gunEspContainer then gunEspContainer:Destroy() gunEspContainer = nil end
end

GunEspButton.MouseButton1Click:Connect(function()
	gunEspActive = not gunEspActive
	if gunEspActive then
		GunEspButton.Text = "Dropped Gun ESP: ON"
		GunEspButton.TextColor3 = Color3.fromRGB(240, 80, 80)
		
		gunEspContainer = Instance.new("Folder")
		gunEspContainer.Name = "Gun_ESP_Container"
		gunEspContainer.Parent = ScreenGui
		
		task.spawn(function()
			while gunEspActive do
				local targetGun = Workspace:FindFirstChild("GunDrop")
				if not targetGun then
					for _, item in ipairs(Workspace:GetDescendants()) do
						if item:IsA("Model") and item.Name == "GunDrop" then
							targetGun = item
							break
						end
					end
				end
				
				if targetGun and not gunEspContainer:FindFirstChild("GunHighlight") then
					local high = Instance.new("Highlight")
					high.Name = "GunHighlight"
					high.Adornee = targetGun
					high.FillColor = Color3.fromRGB(255, 215, 0)
					high.OutlineColor = Color3.fromRGB(255, 255, 255)
					high.FillTransparency = 0.3
					high.Parent = gunEspContainer
				end
				task.wait(1)
			end
		end)
	else
		GunEspButton.Text = "Dropped Gun ESP: OFF"
		GunEspButton.TextColor3 = Themes[currentTheme].ButtonText
		cleanGunEsp()
	end
end)

----------------------------------------------------------------
-- REWRITTEN AUTO GET GUN SYSTEM
----------------------------------------------------------------
local autoGetGunActive = false
local gunCheckConnection = nil

AutoGetGunButton.MouseButton1Click:Connect(function()
	autoGetGunActive = not autoGetGunActive
	if autoGetGunActive then
		AutoGetGunButton.Text = "Auto Get Gun: ON"
		AutoGetGunButton.TextColor3 = Color3.fromRGB(240, 80, 80)
		
		gunCheckConnection = RunService.Heartbeat:Connect(function()
			local myChar = localPlayer.Character
			local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
			if not myRoot then return end
			
			local droppedGun = Workspace:FindFirstChild("GunDrop")
			if not droppedGun then
				for _, v in ipairs(Workspace:GetDescendants()) do
					if v:IsA("Model") and v.Name == "GunDrop" or (v:IsA("BasePart") and v.Name == "GunDrop") then 
						droppedGun = v 
						break 
					end
				end
			end
			
			if droppedGun then
				local targetCFrame
				if droppedGun:IsA("Model") then
					targetCFrame = droppedGun.PrimaryPart and droppedGun.PrimaryPart.CFrame or droppedGun:FindFirstChildWhichIsA("BasePart").CFrame
				else
					targetCFrame = droppedGun.CFrame
				end
				
				if targetCFrame then
					local previousPosition = myRoot.CFrame
					myRoot.CFrame = targetCFrame
					task.wait(0.05)
					myRoot.CFrame = previousPosition
				end
			end
		end)
	else
		AutoGetGunButton.Text = "Auto Get Gun: OFF"
		AutoGetGunButton.TextColor3 = Themes[currentTheme].ButtonText
		if gunCheckConnection then gunCheckConnection:Disconnect() gunCheckConnection = nil end
	end
end)

local processingWin = false
MurderWinButton.MouseButton1Click:Connect(function()
	if processingWin then return end
	local myChar = localPlayer.Character
	local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not myRoot then return end
	
	local knife = localPlayer.Backpack:FindFirstChild("Knife") or myChar:FindFirstChild("Knife")
	if not knife then
		MurderWinButton.Text = "Error: You aren't Murderer!"
		MurderWinButton.TextColor3 = Color3.fromRGB(255, 50, 50)
		task.wait(1.5)
		MurderWinButton.Text = "Auto Win Murderer"
		MurderWinButton.TextColor3 = Themes[currentTheme].ButtonText
		return
	end
	
	processingWin = true
	MurderWinButton.Text = "Eliminating Targets..."
	MurderWinButton.TextColor3 = Color3.fromRGB(255, 255, 100)
	
	task.spawn(function()
		if knife.Parent == localPlayer.Backpack then knife.Parent = myChar end
		local winNoclip = RunService.Stepped:Connect(function()
			if myChar then
				for _, p in ipairs(myChar:GetDescendants()) do
					if p:IsA("BasePart") then p.CanCollide = false end
				end
			end
		end)
		
		while processingWin do
			local targetsAlive = 0
			for _, target in ipairs(Players:GetPlayers()) do
				if target ~= localPlayer and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
					local targetHum = target.Character:FindFirstChildOfClass("Humanoid")
					if targetHum and targetHum.Health > 0 then
						targetsAlive = targetsAlive + 1
						myRoot.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 1)
						pcall(function() knife:Activate() end)
						task.wait(0.12)
					end
				end
			end
			if targetsAlive == 0 then break end
			task.wait(0.1)
		end
		if winNoclip then winNoclip:Disconnect() end
		processingWin = false
		MurderWinButton.Text = "Match Cleared!"
		MurderWinButton.TextColor3 = Color3.fromRGB(100, 255, 100)
		task.wait(2)
		MurderWinButton.Text = "Auto Win Murderer"
		MurderWinButton.TextColor3 = Themes[currentTheme].ButtonText
	end)
end)

----------------------------------------------------------------
-- COIN FARMING SECTION WITH OPTIMIZED 0.5 SEC DELAY CYCLE
----------------------------------------------------------------
local FarmButton = createFeatureButton("Auto Coin Farm: OFF", Views["Farming"].Frame)

local farmActive = false
local farmConnection = nil
local farmNoclipConnection = nil
local farmSpeed = 45 
local waitingForDelay = false

local function getCoinContainer()
	for _, child in ipairs(Workspace:GetChildren()) do
		if child.Name == "Normal" or child:FindFirstChild("CoinContainer") then
			return child:FindFirstChild("CoinContainer")
		end
	end
	return Workspace:FindFirstChild("CoinContainer")
end

local function getNearestCoin(playerRoot)
	local container = getCoinContainer()
	if not container then return nil end
	
	local closestCoin = nil
	local shortestDistance = math.huge
	
	for _, coin in ipairs(container:GetChildren()) do
		if coin:IsA("BasePart") or (coin:IsA("Model") and coin.PrimaryPart) then
			local coinPos = coin:IsA("BasePart") and coin.Position or coin.PrimaryPart.Position
			local distance = (playerRoot.Position - coinPos).Magnitude
			
			if distance < shortestDistance then
				shortestDistance = distance
				closestCoin = coin
			end
		end
	end
	return closestCoin
end

FarmButton.MouseButton1Click:Connect(function()
	farmActive = not farmActive
	
	if farmActive then
		if flying then flying = false clearFlightObjects() FlyButton.Text = "Fly: OFF" end
		
		FarmButton.Text = "Auto Coin Farm: ON"
		FarmButton.TextColor3 = Color3.fromRGB(240, 80, 80)
		waitingForDelay = false
		
		farmNoclipConnection = RunService.Stepped:Connect(function()
			local char = localPlayer.Character
			if char then
				for _, part in ipairs(char:GetDescendants()) do
					if part:IsA("BasePart") then
						part.CanCollide = false
					end
				end
			end
		end)
		
		farmConnection = RunService.Heartbeat:Connect(function()
			if waitingForDelay then return end
			
			local char = localPlayer.Character
			local root = char and char:FindFirstChild("HumanoidRootPart")
			local humanoid = char and char:FindFirstChildOfClass("Humanoid")
			if not root or not humanoid then return end
			
			humanoid.PlatformStand = true
			root.Velocity = Vector3.new(0, 0, 0)
			
			local targetCoin = getNearestCoin(root)
			
			if targetCoin then
				local coinPos = targetCoin:IsA("BasePart") and targetCoin.Position or targetCoin.PrimaryPart.Position
				local targetPosition = Vector3.new(coinPos.X, coinPos.Y + 0.5, coinPos.Z) -- Level height alignment
				local direction = (targetPosition - root.Position)
				local distance = direction.Magnitude
				
				if distance > 1.8 then
					local moveStep = direction.Unit * math.min(farmSpeed * RunService.Heartbeat:Wait(), distance)
					root.CFrame = CFrame.new(root.Position + moveStep, Vector3.new(coinPos.X, root.Position.Y, coinPos.Z))
				else
					-- STABILIZED LOGIC: Sets absolute position frame, blocks runtime, waits 0.5 seconds for pickup registration
					root.CFrame = CFrame.new(targetPosition, Vector3.new(coinPos.X, root.Position.Y, coinPos.Z))
					waitingForDelay = true
					task.spawn(function()
						task.wait(0.5)
						waitingForDelay = false
					end)
				end
			end
		end)
	else
		FarmButton.Text = "Auto Coin Farm: OFF"
		FarmButton.TextColor3 = Themes[currentTheme].ButtonText
		
		if farmConnection then farmConnection:Disconnect() farmConnection = nil end
		if farmNoclipConnection then farmNoclipConnection:Disconnect() farmNoclipConnection = nil end
		
		local char = localPlayer.Character
		local humanoid = char and char:FindFirstChildOfClass("Humanoid")
		if humanoid then humanoid.PlatformStand = false end
		
		if not generalNoclip then stopNoclip() end
	end
end)


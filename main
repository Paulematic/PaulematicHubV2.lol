	ColorSequenceKeypoint.new(0, Color3.fromRGB(18, 10, 10)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(28, 12, 12))
})
MainGradient.Rotation = 45
MainGradient.Parent = MainFrame


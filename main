-- BACKGROUND RADIAL DESIGN
----------------------------------------------------------------
local function createBackgroundCircle(color, size, startPos)
	local Circle = Instance.new("Frame")
	Circle.Size = UDim2.new(0, size, 0, size)
	Circle.Position = startPos
	Circle.BackgroundColor3 = color
	Circle.BackgroundTransparency = 0.91
	Circle.BorderSizePixel = 0
	Circle.ZIndex = 1
	Circle.Parent = MainFrame

	local CircleCorner = Instance.new("UICorner") CircleCorner.CornerRadius = UDim.new(1, 0) CircleCorner.Parent = Circle
	table.insert(backgroundCircles, Circle)
	
	task.spawn(function()
		while MainFrame and Circle.Parent do
			local targetX = startPos.X.Offset + math.random(-30, 30)
			local targetY = startPos.Y.Offset + math.random(-30, 30)
			local randomTime = math.random(5, 8)
			local tween = TweenService:Create(Circle, TweenInfo.new(randomTime, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
				Position = UDim2.new(startPos.X.Scale, targetX, startPos.Y.Scale, targetY)
			})
			tween:Play()
			tween.Completed:Wait()
		end
	end)
end

createBackgroundCircle(Color3.fromRGB(140, 20, 20), 180, UDim2.new(0, -30, 0, -20))
createBackgroundCircle(Color3.fromRGB(100, 15, 40), 220, UDim2.new(1, -160, 1, -160))


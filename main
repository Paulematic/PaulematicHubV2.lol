local currentTheme = "Crimson"
local backgroundCircles = {}
local registeredButtons = {}
local registeredTabs = {}

local ToggleButton = Instance.new("TextButton")
local SprintMainFrame = Instance.new("Frame")
local SprintTitle = Instance.new("TextLabel")
local SprintStroke = Instance.new("UIStroke")
local SprintActionBtn = Instance.new("TextButton")
local SprintActionStroke = Instance.new("UIStroke")
local BindActionBtn = Instance.new("TextButton")
local BindActionStroke = Instance.new("UIStroke")
local SprintClose = Instance.new("TextButton")

local function applyTheme(themeName)
	local cfg = Themes[themeName]
	if not cfg then return end
	currentTheme = themeName
	
	TweenService:Create(MainFrame, TweenInfo.new(0.3), {BackgroundColor3 = cfg.Main}):Play()
	TweenService:Create(FrameStroke, TweenInfo.new(0.3), {Color = cfg.Accent}):Play()
	if MainFrame:FindFirstChild("Title") then
		TweenService:Create(MainFrame.Title, TweenInfo.new(0.3), {TextColor3 = cfg.Text}):Play()
	end
	
	MainGradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, cfg.Gradient1),
		ColorSequenceKeypoint.new(1, cfg.Gradient2)
	})
	
	if MainFrame:FindFirstChild("ContentFrame") then
		TweenService:Create(MainFrame.ContentFrame, TweenInfo.new(0.3), {BackgroundColor3 = cfg.PanelBg}):Play()
		local stroke = MainFrame.ContentFrame:FindFirstChildOfClass("UIStroke")
		if stroke then TweenService:Create(stroke, TweenInfo.new(0.3), {Color = cfg.PanelStroke}):Play() end
	end
	
	if backgroundCircles[1] then TweenService:Create(backgroundCircles[1], TweenInfo.new(0.4), {BackgroundColor3 = cfg.Circle1}):Play() end
	if backgroundCircles[2] then TweenService:Create(backgroundCircles[2], TweenInfo.new(0.4), {BackgroundColor3 = cfg.Circle2}):Play() end
	
	TweenService:Create(ToggleButton, TweenInfo.new(0.3), {BackgroundColor3 = cfg.TabInactive, TextColor3 = cfg.Text}):Play()
	if ToggleButton:FindFirstChildOfClass("UIStroke") then
		ToggleButton:FindFirstChildOfClass("UIStroke").Color = cfg.Accent
	end
	
	TweenService:Create(SprintMainFrame, TweenInfo.new(0.3), {BackgroundColor3 = cfg.Main}):Play()
	TweenService:Create(SprintTitle, TweenInfo.new(0.3), {TextColor3 = cfg.Text}):Play()
	TweenService:Create(SprintStroke, TweenInfo.new(0.3), {Color = cfg.Accent}):Play()
	TweenService:Create(SprintClose, TweenInfo.new(0.3), {BackgroundColor3 = cfg.TabInactive, TextColor3 = cfg.Text}):Play()
	
	if SprintMainFrame:GetAttribute("ToggledState") ~= true then
		TweenService:Create(SprintActionBtn, TweenInfo.new(0.2), {BackgroundColor3 = cfg.ButtonBg, TextColor3 = cfg.ButtonText}):Play()
		TweenService:Create(SprintActionStroke, TweenInfo.new(0.2), {Color = cfg.ButtonStroke}):Play()
	else
		TweenService:Create(SprintActionBtn, TweenInfo.new(0.2), {BackgroundColor3 = cfg.TabActive, TextColor3 = cfg.TabTextActive}):Play()
		TweenService:Create(SprintActionStroke, TweenInfo.new(0.2), {Color = cfg.Accent}):Play()
	end
	
	TweenService:Create(BindActionBtn, TweenInfo.new(0.2), {BackgroundColor3 = cfg.ButtonBg, TextColor3 = cfg.ButtonText}):Play()
	TweenService:Create(BindActionStroke, TweenInfo.new(0.2), {Color = cfg.ButtonStroke}):Play()
	
	for btn, objects in pairs(registeredButtons) do
		if btn and btn.Parent then
			if btn.TextColor3 == Themes["Crimson"].ButtonText or 
			   btn.TextColor3 == Themes["Midnight"].ButtonText or 
			   btn.TextColor3 == Themes["Emerald"].ButtonText or 
			   btn.TextColor3 == Themes["Amethyst"].ButtonText or 
			   btn.TextColor3 == Themes["Sunset"].ButtonText then
				TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = cfg.ButtonText}):Play()
			end
			TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = cfg.ButtonBg}):Play()
			if objects.Stroke then TweenService:Create(objects.Stroke, TweenInfo.new(0.2), {Color = cfg.ButtonStroke}):Play() end
		end
	end
	
	local currentActiveTab = MainFrame:GetAttribute("ActiveTab")
	for tabName, data in pairs(registeredTabs) do
		if data.Button and data.Button.Parent then
			local isActive = (tabName == currentActiveTab)
			TweenService:Create(data.Button, TweenInfo.new(0.25), {
				BackgroundColor3 = isActive and cfg.TabActive or cfg.TabInactive,
				TextColor3 = isActive and cfg.TabTextActive or cfg.TabTextInactive
			}):Play()
			if data.Stroke then
				TweenService:Create(data.Stroke, TweenInfo.new(0.25), {Color = isActive and cfg.Accent or cfg.ButtonStroke}):Play()
			end
		end
	end
end

